{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "types": ["vite/client", "react", "react-dom"]
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/api/**/*.ts",
    "src/components/**/*.tsx",
    "src/hooks/**/*.ts",
    "src/lib/**/*.ts",
    "src/pages/**/*.tsx",
    "src/store/**/*.ts",
    "src/types/**/*.ts",
    "src/types/**/*.d.ts"
  ]
}
